# Keiko model gateway environment variables (names only — never commit real secrets).
#
# Credential precedence (highest wins):
#   1. Per-model env vars (KEIKO_MODEL_<UPPER_MODEL_ID>_API_KEY / _BASE_URL)
#   2. Config file value for the same model
#   3. Global fallback (KEIKO_DEFAULT_API_KEY / KEIKO_DEFAULT_BASE_URL)
#
# Per-model variable names derive from the model id with every non-alphanumeric
# character replaced by "_" and the whole id uppercased. Example for the model id
# "example-chat-model": KEIKO_MODEL_EXAMPLE_CHAT_MODEL_API_KEY / KEIKO_MODEL_EXAMPLE_CHAT_MODEL_BASE_URL.

# Path to a JSON gateway config file. Prefer a path outside untrusted workspaces.
KEIKO_CONFIG_FILE=/secure/path/keiko.config.json

# Per-model overrides (one pair per configured model). Example for "example-chat-model":
KEIKO_MODEL_EXAMPLE_CHAT_MODEL_API_KEY=replace-me
KEIKO_MODEL_EXAMPLE_CHAT_MODEL_BASE_URL=https://your-endpoint.example/v1

# Global fallback applied to any provider that has no file value or per-model override.
KEIKO_DEFAULT_API_KEY=replace-me
KEIKO_DEFAULT_BASE_URL=https://your-endpoint.example/v1
