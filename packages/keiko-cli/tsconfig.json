    { "path": "../keiko-tools" },
    { "path": "../keiko-evaluations" },
    { "path": "../keiko-evidence" },
    { "path": "../keiko-verification" },
    { "path": "../keiko-harness" },
    { "path": "../keiko-sdk" },
    { "path": "../keiko-workflows" },
    { "path": "../keiko-server" }
