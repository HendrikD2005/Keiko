{
  "name": "@oscharko-dev/keiko-server",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "description": "Internal server package: local loopback BFF runtime (HTTP/SSE/WebSocket router, CSP, host check, CSRF gate, terminal, browser, files, run engine, SQLite-backed UI store) that mediates the browser presentation tier and the Node-side domain packages (ADR-0019). Not published independently.",
  "main": "./dist/packages/keiko-server/src/index.js",
  "types": "./dist/packages/keiko-server/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/packages/keiko-server/src/index.d.ts",
      "import": "./dist/packages/keiko-server/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@oscharko-dev/keiko-contracts": "*",
    "@oscharko-dev/keiko-security": "*",
    "@oscharko-dev/keiko-model-gateway": "*",
    "@oscharko-dev/keiko-workspace": "*",
    "@oscharko-dev/keiko-tools": "*",
    "@oscharko-dev/keiko-evidence": "*",
    "@oscharko-dev/keiko-harness": "*",
    "@oscharko-dev/keiko-workflows": "*",
    "@oscharko-dev/keiko-memory-vault": "*",
    "@oscharko-dev/keiko-memory-governance": "*",
    "@oscharko-dev/keiko-memory-retrieval": "*",
    "@oscharko-dev/keiko-memory-capture": "*"
  }
}
