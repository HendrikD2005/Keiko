{
  "name": "@oscharko-dev/keiko-workflows",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "description": "Internal workflows package: reviewable developer-assist workflows (unit-test generation, bug investigation), prompts/parsers/guards/report rendering, apply-mode verification gating, and UI descriptors (ADR-0008 + ADR-0009 + ADR-0019). Not published independently.",
  "main": "./dist/packages/keiko-workflows/src/index.js",
  "types": "./dist/packages/keiko-workflows/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/packages/keiko-workflows/src/index.d.ts",
      "import": "./dist/packages/keiko-workflows/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@oscharko-dev/keiko-contracts": "*",
    "@oscharko-dev/keiko-security": "*",
    "@oscharko-dev/keiko-model-gateway": "*",
    "@oscharko-dev/keiko-workspace": "*",
    "@oscharko-dev/keiko-tools": "*",
    "@oscharko-dev/keiko-evidence": "*",
    "@oscharko-dev/keiko-harness": "*"
  }
}
